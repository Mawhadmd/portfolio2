# Copy this file to .env.local and fill in the values.
# All of these are read at request time (not required to `next build`).

# --- Supabase (blog data store) ---
# Required for the /blog pages and the admin dashboard.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# --- Blog admin auth ---
# ADMIN_PASSWORD gates /blog/admin/login; JWT_SECRET signs the session cookie.
ADMIN_PASSWORD=
JWT_SECRET=

# --- Spotify "now playing" widget (/api/spotify) ---
CLIENT_ID=
CLIENT_SECRET=
REFRESH_TOKEN=

# --- Contact form email (nodemailer via Gmail) ---
# GOOGLE_APP_PASSWORD is a Gmail App Password, not your account password.
GOOGLE_EMAIL=
GOOGLE_APP_PASSWORD=
